{
  "manifest_version": 3,
  "name": "BFLIX Stream Catcher & M3U8 to MP4 Downloader",
  "version": "1.0.0",
  "description": "Automatically catches .m3u8 and video stream sources from web players and converts/downloads them to MP4 files.",
  "permissions": [
    "webRequest",
    "storage",
    "downloads",
    "activeTab",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
